model LendingRecord {
  id              String         @id @default(cuid())

  userId          String
  user            UserAccount    @relation(fields: [userId], references: [id], onDelete: Cascade)

  person          String
  kind            LendingKind

  currency        String         @default("INR")

  principalAmount Decimal        @db.Decimal(18, 2)
  currentBalance  Decimal        @db.Decimal(18, 2)

  dueDate         DateTime?
  status          LendingStatus  @default(OPEN)
  settledAt       DateTime?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, kind, status])
  @@index([userId, dueDate])
}
enum LendingKind {
  LENT
  LOAN
}

enum LendingStatus {
  OPEN
  SETTLED
  WRITTEN_OFF
}
