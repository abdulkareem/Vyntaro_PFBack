generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////
// USER & AUTH
//////////////////////////////

model UserAccount {
  id     String    @id @default(cuid())
  phone  String    @unique
  email  String?   @unique
  role   UserRole  @default(USER)
  pinSet Boolean   @default(false)
  authState AuthState @default(IDENTITY_VERIFIED)
  pinResetAllowed Boolean @default(false)
  pinResetAllowedUntil DateTime?

  userStatus    UserStatus    @default(GHOST)
  accountStatus AccountStatus @default(ACTIVE)

  referralCode String  @unique
  referredById String?

  freeMonthsEarned Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One-to-one (virtual side)
  subscription Subscription?

  referredBy UserAccount?  @relation("UserReferrals", fields: [referredById], references: [id])
  referrals  UserAccount[] @relation("UserReferrals")

  devices UserDevice[]
  userPin UserPin?
  otps    VerificationCode[]
  authTransitions AuthStateTransition[]

  financialAccounts    FinancialAccount[]
  categories           Category[]
  journalEntries       JournalEntry[]
  budgetPlans          BudgetPlan[]
  lendingRecords       LendingRecord[]
  receipts             Receipt[]
  vehicleBills         VehicleBill[]
  assistantSuggestions AssistantSuggestion[]

  referralsMade     Referral[] @relation("Referrer")
  referralsReceived Referral[] @relation("Referee")
}

model UserDevice {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  fingerprint String
  isTrusted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
}

model VerificationCode {
  id         String     @id @default(cuid())
  userId     String
  purpose    OtpPurpose
  channel    OtpChannel
  codeHash   String
  expiresAt  DateTime
  attempts   Int        @default(0)
  maxAttempts Int       @default(3)
  resendCount Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthStateTransition {
  id        String    @id @default(cuid())
  userId    String
  fromState AuthState
  toState   AuthState
  reason    String
  createdAt DateTime  @default(now())

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPin {
  id      String @id @default(cuid())
  userId  String @unique
  pinHash String

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////
// SUBSCRIPTIONS & FEATURES
//////////////////////////////

model SubscriptionPlan {
  id           String  @id @default(cuid())
  name         String
  price        Decimal @db.Decimal(10, 2)
  durationDays Int
  isActive     Boolean @default(true)

  features PlanFeature[]
  cards    PlanDashboardCard[]

  createdAt    DateTime       @default(now())
  Subscription Subscription[]
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String             @unique
  planId         String
  status         SubscriptionStatus
  startDate      DateTime
  endDate        DateTime
  freeMonthsUsed Int                @default(0)

  user UserAccount      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
}

model PlanFeature {
  id      String     @id @default(cuid())
  planId  String
  feature AppFeature

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, feature])
}

model PlanDashboardCard {
  id        String            @id @default(cuid())
  planId    String
  cardType  DashboardCardType
  isEnabled Boolean           @default(true)

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, cardType])
}

//////////////////////////////
// REFERRALS
//////////////////////////////

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  refereeId  String
  rewarded   Boolean  @default(false)
  createdAt  DateTime @default(now())

  referrer UserAccount @relation("Referrer", fields: [referrerId], references: [id])
  referee  UserAccount @relation("Referee", fields: [refereeId], references: [id])

  @@unique([referrerId, refereeId])
}

//////////////////////////////
// ACCOUNTING
//////////////////////////////

model FinancialAccount {
  id             String      @id @default(cuid())
  userId         String
  name           String
  accountType    AccountType
  currency       String      @default("INR")
  openingBalance Decimal     @db.Decimal(18, 2)

  user         UserAccount   @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]
}

model JournalEntry {
  id              String      @id @default(cuid())
  userId          String
  transactionDate DateTime
  source          EntrySource
  description     String?

  user  UserAccount   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lines JournalLine[]
}

model JournalLine {
  id             String         @id @default(cuid())
  journalEntryId String
  accountId      String
  categoryId     String?
  direction      EntryDirection
  amount         Decimal        @db.Decimal(18, 2)

  journalEntry JournalEntry     @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      FinancialAccount @relation(fields: [accountId], references: [id])
  category     Category?        @relation(fields: [categoryId], references: [id])
}

//////////////////////////////
// DASHBOARD CATEGORIES
//////////////////////////////

model Category {
  id     String         @id @default(cuid())
  userId String
  name   String
  slug   String
  kind   CategoryKind
  bucket CategoryBucket

  showOnDashboard Boolean           @default(false)
  dashboardOrder  Int?
  cardType        DashboardCardType @default(CUSTOM)

  user        UserAccount   @relation(fields: [userId], references: [id], onDelete: Cascade)
  JournalLine JournalLine[]

  @@unique([userId, slug])
}

//////////////////////////////
// LENDING
//////////////////////////////

model LendingRecord {
  id              String        @id @default(cuid())
  userId          String
  person          String
  kind            LendingKind
  principalAmount Decimal       @db.Decimal(18, 2)
  currentBalance  Decimal       @db.Decimal(18, 2)
  status          LendingStatus

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////
// EXTERNAL SOURCES & BILLS
//////////////////////////////

model ExternalSource {
  id         String             @id @default(cuid())
  sourceType ExternalSourceType
  name       String?
  isTrusted  Boolean            @default(false)
  createdAt  DateTime           @default(now())
}

model Receipt {
  id               String         @id @default(cuid())
  userId           String
  externalSourceId String?
  merchantName     String?
  purchasedAt      DateTime
  totalAmount      Decimal        @db.Decimal(18, 2)
  currency         String         @default("INR")
  sourceType       BillSourceType
  rawPayload       Json?

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VehicleBill {
  id            String         @id @default(cuid())
  userId        String
  driverName    String?
  vehicleNumber String?
  totalAmount   Decimal        @db.Decimal(18, 2)
  distanceKm    Decimal?
  sourceType    BillSourceType

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////
// AI SUGGESTIONS
//////////////////////////////

model AssistantSuggestion {
  id              String         @id @default(cuid())
  userId          String
  suggestionType  SuggestionType
  title           String
  message         String
  confidenceScore Decimal?

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////
// BUDGET
//////////////////////////////

model BudgetPlan {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////
// ENUMS
//////////////////////////////

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  GHOST
  ACTIVE
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AppFeature {
  DASHBOARD
  BUDGET
  ANALYTICS
  BILLS
  LENDING
  REPORTS
}

enum CategoryBucket {
  FOOD
  TRANSPORT
  HOUSING
  HEALTH
  ENTERTAINMENT
  SAVINGS
  INVESTMENT
  CHARITY
  MONEY_LENT
  MONEY_BORROWED
  OTHER
}

enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
}

enum EntrySource {
  MANUAL
  IMPORT
  BILL_CAPTURE
  CHAT
  AI
}

enum EntryDirection {
  DEBIT
  CREDIT
}

enum LendingKind {
  LENT
  LOAN
}

enum LendingStatus {
  OPEN
  SETTLED
  WRITTEN_OFF
}

enum ExternalSourceType {
  MERCHANT_APP
  VEHICLE_APP
  POS
  USER_SCAN
}

enum BillSourceType {
  IMAGE
  TEXT
  FILE
  EXTERNAL
}

enum SuggestionType {
  BUDGET
  REORDER
  TRAVEL
  CASHFLOW
  TAX
}

enum OtpChannel {
  PHONE
  EMAIL
  DEVICE
}

enum OtpPurpose {
  REGISTER
  PIN_RESET
}

enum AuthState {
  IDENTITY_VERIFIED
  OTP_VERIFIED
  PIN_SET
  ACTIVE
}

enum DashboardCardType {
  SUMMARY
  CHART
  LIST
  CUSTOM
}

enum CategoryKind {
  INCOME
  EXPENSE
  TRANSFER
}
